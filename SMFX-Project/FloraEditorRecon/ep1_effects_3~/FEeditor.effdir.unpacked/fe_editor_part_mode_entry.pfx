shake shake-0
	length 3
	amplitude 0 0.15 0.2 0
	frequency 20 5
	table sineY
end

import fe_editor_part_mode_grasses

import fe_editor_part_mode_trees

effect fe_editor_part_mode_entry
	shake shake-0
	effect fe_editor_part_mode_grasses -offset (0, 0, -0.4)
	effect fe_editor_part_mode_trees -offset (0, 0, -0.4)
end

export fe_editor_part_mode_entry
